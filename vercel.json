{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 25,
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/voice",
            "destination": "/voice.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)\\.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        },
        {
            "source": "/voice",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        }
    ]
}
